{
  "name": "k2gl/phpunit-fluent-assertions",
  "description": "Improves test code readability.",
  "homepage": "https://github.com/k2gl/phpunit-fluent-assertions",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "phpunit",
    "xunit",
    "testing"
  ],
  "authors": [
    {
      "name": "Nickolay Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "support": {
    "issues": "https://github.com/k2gl/phpunit-fluent-assertions/issues",
    "source": "https://github.com/k2gl/phpunit-fluent-assertions"
  },
  "require": {
    "php": ">=8.1",
    "phpunit/phpunit": "^9|^10|^11|^12"
  },
  "autoload": {
    "psr-4": {
      "K2gl\\PHPUnitFluentAssertions\\": "src/"
    },
    "files": [
      "src/aliases.php"
    ]
  },
   "autoload-dev": {
     "psr-4": {
       "K2gl\\PHPUnitFluentAssertions\\Tests\\": "tests/"
     }
   },
   "minimum-stability": "stable",
   "scripts": {
      "test": "phpunit",
      "phpstan": "phpstan analyse",
      "cs": "pint --test",
      "cs-fix": "pint",
      "check": [
        "@test",
        "@phpstan",
        "@cs"
      ]
   },
    "require-dev": {
     "phpstan/phpstan": "^2.1",
     "laravel/pint": "~1.20.0"
   },
   "extra": {
     "phpstan": {
       "includes": [
         "extension.neon"
       ]
     }
   }
}
